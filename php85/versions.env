# =============================================================================
# macOS-php / php85 — pinned versions & locations
# Sourced by compile-php.sh. Override any value via the environment before
# running (e.g. PREFIX=/tmp/php ./compile-php.sh).
# =============================================================================

# Where the finished PHP lands. Self-contained prefix: PHP + every vendored
# library in one tree, with absolute install_names → works without DYLD_*.
#
# IMPORTANT: this path is BAKED into the binaries (absolute install_names).
# A bundle downloaded from Releases MUST be extracted to exactly this prefix
# (install.sh does that). Changing PREFIX = full rebuild required.
: "${PREFIX:=/opt/php8.5}"

# Scratch dir for sources + logs (safe to delete after a successful build).
: "${WORK:=$HOME/php85-build}"

# Cores used for compilation.
: "${JOBS:=$(sysctl -n hw.ncpu)}"

# Minimum macOS version baked into the binaries (deployment target).
: "${MACOS_MIN:=11.0}"

# ---- PHP --------------------------------------------------------------------
# Official php-src, PHP-8.5 branch (8.5 is supported natively — no fork needed).
: "${PHP_SRC_REPO:=https://github.com/php/php-src.git}"
: "${PHP_SRC_REF:=PHP-8.5}"

# ---- Vendored dependencies (built from source into $PREFIX) -----------------
# OpenSSL 3.x (PHP 8.5 targets OpenSSL 3).
: "${OPENSSL_VER:=3.5.1}"
# GNU libiconv: the macOS SDK ships only a .tbd stub (no real .dylib) → build it
# (the iconv extension needs the GNU symbols).
: "${LIBICONV_VER:=1.17}"
# zlib.
: "${ZLIB_VER:=1.3.1}"
# Oniguruma: PHP 7.4+ unbundled it; mbstring's regex needs the system library.
: "${ONIG_VER:=6.9.10}"
# curl (OpenSSL 3 backend).
: "${CURL_VER:=8.17.0}"
# nginx + statically-linked pcre2 (no Homebrew at runtime).
: "${NGINX_VER:=1.31.1}"
: "${PCRE2_VER:=10.45}"

# NOTE: no ICU here — this build excludes ext/intl (matches the production
# image, where intl is polyfilled). That removes the hardest part of the 5.6
# build (ICU + install_name fixup).

# ---- PECL extensions ---------------------------------------------------------
: "${APCU_VER:=5.1.24}"       # APCu for PHP 8.x

# ---- Derived paths -----------------------------------------------------------
export PREFIX WORK JOBS MACOS_MIN
export SRC="$WORK/src"
export LOGS="$WORK/logs"
