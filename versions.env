# =============================================================================
# macOS-php — pinned versions & locations
# Sourced by compile-php.sh. Override any value via the environment before
# running (e.g. PREFIX=/tmp/php ./compile-php.sh).
# =============================================================================

# Where the finished PHP lands. Self-contained prefix: PHP + every vendored
# library in one tree, with absolute install_names → works without DYLD_*.
#
# IMPORTANT: this path is BAKED into the binaries (absolute install_names).
# A bundle downloaded from Releases MUST be extracted to exactly this prefix
# (install.sh does that). Changing PREFIX = full rebuild required.
: "${PREFIX:=/opt/php56}"

# Scratch dir for sources + logs (safe to delete after a successful build).
: "${WORK:=$HOME/php56-build}"

# Cores used for compilation.
: "${JOBS:=$(sysctl -n hw.ncpu)}"

# Minimum macOS version baked into the binaries (deployment target). A binary
# built for an older target still runs on newer macOS.
: "${MACOS_MIN:=11.0}"

# ---- PHP --------------------------------------------------------------------
# Remi Collet's fork: CVE backports from newer branches onto 5.6, against
# OpenSSL 1.1. This is the only maintained way to get a secure PHP 5.6
# (officially EOL since 2018).
: "${PHP_SRC_REPO:=https://github.com/remicollet/php-src-security.git}"
: "${PHP_SRC_REF:=PHP-5.6-security-backports-openssl11}"

# ---- Vendored dependencies (built from source into $PREFIX) -----------------
# OpenSSL 1.1.1: Homebrew dropped openssl@1.1, and the PHP branch targets 1.1
# (not 3.0).
: "${OPENSSL_VER:=1.1.1w}"
# ICU 66.1: newer ICU fails to compile ext/intl from PHP 5.6.
: "${ICU_VER_TAG:=release-66-1}"
: "${ICU_VER_FILE:=66_1}"
# ICU data filter (ICU_DATA_FILTER_FILE) — trims libicudata (full ~27M) down to
# selected languages. Space-separated list; EMPTY = full ICU data.
# Add languages if ext/intl needs them in your case.
: "${ICU_LOCALES:=en}"
export ICU_LOCALES
# GNU libiconv: the macOS SDK ships only a .tbd stub (no real .dylib) → build it.
: "${LIBICONV_VER:=1.17}"
# zlib into the prefix: lets us use --with-zlib-dir=$PREFIX and NOT inject
# -L$SDK/usr/lib (which broke ordering and picked up the system libiconv).
: "${ZLIB_VER:=1.3.1}"
# curl: 8.17.0 is the last line that builds against OpenSSL 1.1.x.
: "${CURL_VER:=8.17.0}"
# nginx: stable line; links our OpenSSL 1.1.1w and a statically-built pcre2.
: "${NGINX_VER:=1.31.1}"
# pcre2: built FROM SOURCE and linked statically into the nginx binary, so the
# result needs no Homebrew at runtime (fully self-contained).
: "${PCRE2_VER:=10.45}"

# ---- Helper toolchain --------------------------------------------------------
# autoconf 2.69: 2.70+ mis-expands PHP 5.6's legacy m4 (corrupted `configure`).
# Built locally.
: "${AUTOCONF_LEGACY_VER:=2.69}"

# ---- PECL extensions ---------------------------------------------------------
: "${APCU_VER:=4.0.11}"       # last APCu branch supporting PHP 5.6
: "${TIDEWAYS_VER:=3.0.3}"    # XHProf-compatible profiler (drop-in xhprof_*)

# ---- Derived paths -----------------------------------------------------------
export PREFIX WORK JOBS MACOS_MIN
export SRC="$WORK/src"
export LOGS="$WORK/logs"
export AC269_PREFIX="$WORK/ac269"
